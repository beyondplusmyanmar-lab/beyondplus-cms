# Uploaded files are content, never code. This prevents a file that slips past
# validation from being executed as a script (defense in depth). The app also
# validates that only real images are stored.
#
# NOTE: this is Apache-only. On nginx, add an equivalent `location` block that
# denies script execution under /uploads.

# Turn off the PHP engine for this directory (mod_php).
<IfModule mod_php.c>
    php_admin_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_admin_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_admin_flag engine off
</IfModule>

# Deny access to any executable / script file types.
<FilesMatch "(?i)\.(php|php3|php4|php5|php7|php8|phtml|pht|phar|cgi|pl|py|asp|aspx|jsp|sh|htaccess)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
