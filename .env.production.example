# Merchant production template — Merchant Deployment v1
# (docs/MERCHANT-DEPLOYMENT-V1.md §2). Copy to .env, fill every ⟨…⟩, then:
#   php artisan key:generate && php artisan migrate --seed
# One merchant = one installation = one database (frozen decision D1).
# DOEH keys (sk_/pk_/client_id) are NOT env values — the setup wizard collects,
# live-validates and stores them; never put them in this file.

APP_NAME="⟨Merchant name⟩"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://⟨merchant-domain⟩

LOG_CHANNEL=stack

# The merchant's own database (MySQL/MariaDB in production).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=⟨merchant_db⟩
DB_USERNAME=⟨merchant_db_user⟩
DB_PASSWORD=⟨strong-password⟩

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Outbound mail (password resets, notifications) — the merchant's SMTP.
MAIL_MAILER=smtp
MAIL_HOST=⟨smtp-host⟩
MAIL_PORT=587
MAIL_USERNAME=⟨smtp-user⟩
MAIL_PASSWORD=⟨smtp-password⟩
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=⟨no-reply@merchant-domain⟩
MAIL_FROM_NAME="${APP_NAME}"

# Behind nginx / a load balancer / Cloudflare: trust X-Forwarded-* or HTTPS
# detection and client IPs break. "*" trusts all; prefer the proxy's IPs/CIDRs.
TRUSTED_PROXIES=⟨proxy-ip-or-cidr⟩
